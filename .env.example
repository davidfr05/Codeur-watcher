# Copie ce fichier en ".env" et remplis les valeurs.

# Clé API Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# --- Email de notification (SMTP) ---
# Exemple avec Gmail : crée un "mot de passe d'application" (pas ton mot de passe normal).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton.email@gmail.com
SMTP_PASS=mot_de_passe_application
# Adresse qui reçoit les alertes (souvent la même que SMTP_USER)
NOTIFY_TO=ton.email@gmail.com
